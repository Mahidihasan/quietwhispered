# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/personal-journal
MONGODB_TEST_URI=mongodb://localhost:27017/personal-journal-test

# JWT Configuration
JWT_SECRET=your-generated-secret-key-here-change-this-in-production
JWT_EXPIRE=24h
JWT_COOKIE_EXPIRE=30

# Server Configuration
PORT=5000
NODE_ENV=development

# File Upload Configuration
MAX_FILE_UPLOAD=10000000
FILE_UPLOAD_PATH=./uploads

# Admin Default Credentials (CHANGE THESE IMMEDIATELY!)
ADMIN_USERNAME=admin
ADMIN_INITIAL_PASSWORD=YourStrongPassword!2024#MinLength12Chars

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
